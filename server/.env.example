MONGODB_URI=mongodb://localhost:27017/hathap
JWT_SECRET=replace_this_with_a_secure_random_string
PORT=4000

# A2A (Agent-to-Agent) protocol
A2A_BASE_URL=http://localhost:4000
# Optional service auth: set both to allow X-A2A-API-Key access without JWT
# A2A_API_KEY=your-secret-a2a-key
# A2A_DEFAULT_USER_ID=mongodb-user-id-for-service-account
